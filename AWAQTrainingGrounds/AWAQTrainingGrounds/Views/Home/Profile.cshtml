@{
    ViewData["Title"] = "Home";
}

<div class="container text-center">
  <div class="row gx-1 align-items-stretch">
    <div class="col-sm-4 mb-1">
        <div class="card h-100">
             <div class = "mb-4 mt-4 profile-img-container">
                <img src="@Model.profile_url" class = "rounded-circle" id = "profile" width="192" height="192">
            </div>
            <div class="card-body text-start">
                <h5 class="card-title">@Model.User.nombre</h5>
                <p class="card-text text-muted">@Model.User.correo</p>
            </div>
        </div>

    </div>
    <div class="col-sm mb-1">
        <div class="card w-100 h-100">
            
            <div class="card-body d-flex flex-column flex-grow-1 text-start">
                <div class="row w-100 h-100">
                    <div class="col-4">
                        <div class="card w-100 h-100 d-flex flex-column">
                            <img src="~/Images/Home/PaperRush.png" class="profile-img">
                            <div class="card-body text-start">
                                <h5 class="card-title">Paper Rush</h5>
                                <p class="small">
                                    Récord: @Model.gameWin1/90
                                    <i class="bi bi-coin"></i>
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="card w-100 h-100 d-flex flex-column">
                            <img src="~/Images/Home/Dudas.png" class="profile-img">
                            <div class="card-body text-start">
                                <h5 class="card-title">Rythm Attack</h5>
                                <p class="small">
                                    Récord: @Model.gameWin2/90
                                    <i class="bi bi-coin"></i>
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                       <div class="card w-100 h-100 d-flex flex-column">
                            <img src="~/Images/Home/Puestos.png" class="profile-img">
                            <div class="card-body text-start">
                                <h5 class="card-title">Task Match</h5>
                                <p class="small">
                                    Récord: @Model.gameWin3/90
                                    <i class="bi bi-coin"></i>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    </div>
    <div class="row gx-1 align-items-stretch">
        <div class="col-sm-4">
            <div class="card mb-3 h-100">
                <div class="card-body text-start small">
                    <div class="mb-3 d-flex gap-2">
                        <i class="bi bi-globe"></i>
                        <div>
                            <strong>País:</strong><br>
                            <span class="text-muted">@Model.User.name</span>
                        </div>
                    </div>
                    <div class="mb-3 d-flex gap-2">
                        <i class="bi bi-cake2"></i>
                        <div>
                            <strong>Cumpleaños:</strong><br>
                            <span class="text-muted">@Model.User.fecha_de_nacimiento.ToString("dd/MM/yyyy")</span>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <i class="bi bi-telephone"></i>
                        <div>
                            <strong>Teléfono:</strong><br>
                            <span class="text-muted">@Model.User.telefono</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm">
            <div class="card h-100">
                <div class="card-body text-start small">
                    <div class="mb-3 d-flex gap-2">
                        <i class="bi bi-coin"></i>
                        <div>
                            <strong>Monedas:</strong><br>
                            <span class="text-muted">@Model.Coins</span>
                        </div>
                    </div>
                    
                    <div class="mb-3 d-flex gap-2">
                        <i class="bi bi-controller"></i>
                        <div>
                            <strong>Juegos Completados:</strong><br>
                            <span class="text-muted">@Model.GameWins</span>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <i class="bi bi-gift"></i>
                        <div>
                            <strong>Cosméticos Desbloqueados:</strong><br>
                            <span class="text-muted">@Model.CosmeticUnlocks</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

