@model Users

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html>
    <head>
        <title>Login</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="~/css/account.css"/>

    </head>
    <body>
        <section class = "MainBody">
            <h1>Iniciar Sesión</h1>
            <br />
            <form method = "post" class = "needs-validation content" novalidate>
                <div class="mb-3">
                    <label for="loginEmail" class="form-label my-form">Correo</label>
                    <input type="email" id="loginEmail" class="form-control" name= "correo" required>
                    <div class="invalid-feedback" id = "email-error">
                        @if (ViewData.ModelState["correo"]?.Errors.Count > 0)
                        {
                             @Html.ValidationMessageFor(m => m.correo)
                        }
                    </div>
                    
                </div>
                <div class="mb-3">
                    <label for="loginPassword" class="form-label my-form">Password</label>
                    
                    <input type="password" class="form-control" id="loginPassword" name = "encrypted_password" required>
                    <div class="invalid-feedback" id = "password-error">
                        @if (ViewData.ModelState["encrypted_password"]?.Errors.Count > 0)
                        {
                             @Html.ValidationMessageFor(m => m.encrypted_password)
                        }
                    </div>
                </div>
                <br />
                <div class="d-grid gap-2 col-10 mx-auto">
                    <button class="btn btn-primary my-submit-button" type="submit">Iniciar Sesión</button>
                </div>
            </form>
            <script src="~/js/loginValidation.js"></script>
        </section>
            <section class = "SideBody">
            <h1>¡Empieza aquí!</h1>
            <h2>Aquí comienza tu aventura</h2>
            <br />
            <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light my-btn">
                Registrar
            </a>

        </section>
        
    </body>
</html>
