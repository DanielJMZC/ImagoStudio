@using System.Globalization
@model RegisterViewModel

@{
    ViewData["Title"] = "RegisterProfile";
    Layout = null;
    CultureInfo.CurrentCulture = new CultureInfo("es-ES");
}

<!DOCTYPE html>
<html>
    <head>
        <title>Login</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="~/css/account.css"/>

    </head>
    <body class="register-page">
        <section class = "MainBody">
            <h1>Completar Perfil</h1>
            <br />

            <form method= "post" class = "needs-validation content" novalidate>
                <div class="mb-3">
                    <label for="country" class="form-label my-form">País</label>
                    <select class = "form-select" id="country" name = "country_id" required>
                        <option value="" disabled selected>Selecciona un páis</option>
                        <option value="1">🇦🇷 Argentina</option>
                        <option value="2">🇦🇺 Australia</option>
                        <option value="3">🇧🇷 Brazil</option>
                        <option value="4">🇨🇦 Canada</option>
                        <option value="5">🇨🇳 China</option>
                        <option value="6">🇫🇷 France</option>
                        <option value="7">🇩🇪 Germany</option>
                        <option value="8">🇮🇳 India</option>
                        <option value="9">🇮🇹 Italy</option>
                        <option value="10">🇯🇵 Japan</option>
                        <option value="11">🇲🇽 Mexico</option>
                        <option value="12">🇳🇱 Netherlands</option>
                        <option value="13">🇳🇬 Nigeria</option>
                        <option value="14">🇷🇺 Russia</option>
                        <option value="15">🇿🇦 South Africa</option>
                        <option value="16">🇰🇷 South Korea</option>
                        <option value="17">🇪🇸 Spain</option>
                        <option value="18">🇬🇧 United Kingdom</option>
                        <option value="19">🇺🇸 United States</option>
                        <option value="20">🇻🇳 Vietnam</option>
                        
                    </select>
                    <div class="invalid-feedback" id = "country-error">
                        Selecciona un país de la lista.
                    </div>
                </div>
                <div class = "mb-3">
                    <label for="phoneNumber" class="form-label my-form">Teléfono</label>
                    <div class = "input-group has-validation">
                        <select class = "form-select phoneID" id="phoneNumber" name = "telefono_prefix" required>
                            <option value="" disabled selected></option>
                         
                        <option value="+54">🇦🇷 +54</option>
                        <option value="+61">🇦🇺 +61</option>
                        <option value="+55">🇧🇷 +55</option>
                        <option value="+1">🇨🇦 +1</option>
                        <option value="+86">🇨🇳 +86</option>
                        <option value="+33">🇫🇷 +33</option>
                        <option value="+49">🇩🇪 +49</option>
                        <option value="+91">🇮🇳 +91</option>
                        <option value="+39">🇮🇹 +39</option>
                        <option value="+81">🇯🇵 +81</option>
                        <option value="+52">🇲🇽 +52</option>
                        <option value="+31">🇳🇱 +31</option>
                        <option value="+234">🇳🇬 +234</option>
                        <option value="+7">🇷🇺 +7</option>
                        <option value="+27">🇿🇦 +27</option>
                        <option value="+82">🇰🇷 +82</option>
                        <option value="+34">🇪🇸 +34</option>
                        <option value="+44">🇬🇧 +44</option>
                        <option value="+1">🇺🇸 +1</option>
                        <option value="+84">🇻🇳 +84</option>
                        </select>
                        <input type="number" class="form-control phoneNumber" id = "phoneNumber2" name = "telefono"  aria-label="Número de Télefono" required>
                        <div class="invalid-feedback" id = "phone-error">
                        Por favor ingresa un número de teléfono válido con su prefijo.
                        </div>
                    </div>
                    
                </div>
            <div class = "mb-3">
                    <label for="birthdate_day" class="form-label my-form">Fecha de Nacimiento</label>
                    <div class = "input-group has-validation">
                        <select class = "form-select day" id="birth_day" name="birth_day" required>
                            <option value="" disabled selected>Día</option>
                            @for (int i = 1; i <= 31; i++)
                            {
                                <option value="@i">@i</option>
                            }
                        </select>
                        <select class = "form-select month" id="birth_month" name = "birth_month" required>
                            <option value="" disabled selected>Mes</option>
                                @for (int i = 1; i <= 12; i++)
                                {
                                    <option value="@i">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</option>
                                }
                        
                        </select>
                        <select class = "form-select year" id="birth_year" name = "birth_year" required>
                            <option value="" disabled selected>Año</option>

                            @for (int i = DateTime.Now.Year; i >= 1900; i--)
                            {
                                <option value="@i">@i</option>
                            }
                        </select>
                         <div class="invalid-feedback" id = "date-error">
                        Por favor selecciona un rango de fechas válido.
                        </div>
                </div>
        
                <input type="hidden" name="cosmetic_id" id = "profileInput" value="2">
                <br />
                <div class="d-grid gap-2 col-10 mx-auto">
                    <button class="btn btn-primary my-submit-button" type="submit">Completar</button>
                </div>
            </form>
        </section>
        <section class = "SideBody">
            <div class = "mb-3">
                <img src="~/Images/Account/Avatar2.png" class = "rounded-circle" id = "profile" width="192" height="192">
            </div>
            <br />
            <button class="btn btn-outline-light my-btn" type="button" data-bs-toggle="modal" data-bs-target="#profileModal">Editar Perfil</button>
        </section>  

        <div class="modal fade" id="profileModal" tabindex="-1" aria-labelledby="profileModal" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content my-modal-container">
                    <div class="modal-header my-modal">
                        <h1 class="modal-title fs-5" id="profileChooser">Selecciona tu perfil</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <input type="radio" class="btn-check my-input" value="2" name="cosmetic" id="option1" autocomplete="off" checked>
                        <label class = "btn rounded-circle my-radio" for = "option1">
                            <img src="~/Images/Account/Avatar2.png" class = "rounded-circle" width="96" height= "96">
                        </label>

                        <input type="radio" class="btn-check my-input" value="3" name = "cosmetic" id="option2" autocomplete="off">

                        <label class = "btn rounded-circle my-radio" for = "option2">
                        <img src="~/Images/Account/Avatar3.png" class = "rounded-circle" width="96" height= "96">
                        </label>

                        <input type="radio" class="btn-check my-input" value="4" name = "cosmetic" id="option3" autocomplete="off">

                        <label class = "btn rounded-circle my-radio" for = "option3">
                        <img src="~/Images/Account/Avatar4.png" class = "rounded-circle" width="96" height= "96">
                        </label>

                        <input type="radio" class="btn-check my-input" value="5" name = "cosmetic" id="option4" autocomplete="off">

                        <label class = "btn rounded-circle my-radio" for = "option4">
                        <img src="~/Images/Account/Avatar5.png" class = "rounded-circle" width="96" height= "96">
                        </label>

                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <button type="button" class="btn btn-success " id = "profileSubmit" data-bs-dismiss="modal">Save changes</button>
                    </div>
                </div>
            </div>
        </div> 
        <script src="~/js/registerProfileValidation.js"></script>
        <script src="~/js/registerProfileModal.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>
